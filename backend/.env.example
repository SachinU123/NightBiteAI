# ════════════════════════════════════════════════════════════════════════════════
# NightBite AI — Environment Configuration Example
# Copy this file to .env and fill in the required values.
# AI Provider: Anthropic Claude only (no Gemini, no OpenAI)
# ════════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=NightBite AI
APP_ENV=development            # development | staging | production
DEBUG=True                     # Set False in production
API_V1_PREFIX=/api/v1

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://nightbite_user:nightbite_pass@localhost:5432/nightbite_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Use a long, random secret in production. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_strong_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200   # 30 days

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, replace * with specific allowed origins
ALLOWED_ORIGINS=["*"]
ALLOW_CREDENTIALS=true

# ── Anthropic Claude AI ───────────────────────────────────────────────────────
# REQUIRED for AI Coach, smart nudges, and notification classification.
# Get your key at: https://console.anthropic.com
CLAUDE_API_KEY=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

# Claude model — do not change without testing
# claude-3-5-haiku-20241022  (recommended — fast, affordable, high quality)
# claude-3-5-sonnet-20241022 (higher quality, slower, more expensive)
CLAUDE_MODEL=claude-3-5-haiku-20241022

# Set to false to disable all AI features and run deterministic-only
ENABLE_LLM_ENHANCEMENT=true

# AI timeout in seconds — increase if getting timeouts, reduce for faster fallback
AI_TIMEOUT_SECONDS=25

# Max tokens for different response types
AI_MAX_TOKENS_SHORT=400    # Short replies, nudges
AI_MAX_TOKENS_LONG=900     # Detailed explanations, summaries

# ── Android / Network ─────────────────────────────────────────────────────────
# Your machine's IP on the local network — used by the Android device to connect
# Find with: ipconfig (Windows) or ifconfig (Linux/Mac)
PUBLIC_BASE_URL=http://192.168.0.103:8000
ANDROID_CLIENT_TIMEOUT_SECONDS=30

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR
