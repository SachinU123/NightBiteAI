"""
NightBite AI — Gemini Service

Clean, production-safe Gemini wrapper.
- Real timeout enforcement via concurrent.futures
- Strict JSON-only responses with schema validation
- Retry with stricter prompt on parse failure
- Full fallback if Gemini unavailable
- Never crashes the caller
- Detailed logging so failures are visible
"""
from __future__ import annotations

import json
import logging
import concurrent.futures
from typing import Any, Optional, Dict

logger = logging.getLogger(__name__)

_model = None  # Lazy singleton
_executor = concurrent.futures.ThreadPoolExecutor(max_workers=4)


def _get_model():
    """Lazily initialize and cache the Gemini model. Returns None if unavailable."""
    global _model
    if _model is not None:
        return _model

    try:
        import google.generativeai as genai
        from app.core.config import settings

        if not settings.GEMINI_API_KEY:
            logger.warning("GEMINI_API_KEY is not set — Gemini disabled.")
            return None

        genai.configure(api_key=settings.GEMINI_API_KEY)
        model_name = settings.GEMINI_MODEL or "gemini-2.0-flash"
        _model = genai.GenerativeModel(model_name)
        logger.info(f"✅ Gemini model loaded: {model_name}")
        return _model

    except Exception as e:
        logger.error(f"❌ Failed to initialise Gemini: {e}")
        return None


def _reset_model():
    """Reset the cached model so it gets re-initialized on next call."""
    global _model
    _model = None


def call_gemini_text(
    prompt: str,
    timeout_seconds: float = 20.0,
) -> Optional[str]:
    """
    Call Gemini for a free-form text response with REAL timeout enforcement.
    Returns the text reply, or None on any failure.
    """
    model = _get_model()
    if model is None:
        logger.error("Gemini model is None — cannot call API")
        return None

    def _do_call():
        response = model.generate_content(
            prompt,
            generation_config={
                "temperature": 0.75,
                "max_output_tokens": 300,
            },
        )
        return response.text.strip()

    try:
        future = _executor.submit(_do_call)
        result = future.result(timeout=timeout_seconds)
        logger.info(f"✅ Gemini text reply: {result[:80]}...")
        return result
    except concurrent.futures.TimeoutError:
        logger.warning(f"⏱️ Gemini text call timed out after {timeout_seconds}s")
        future.cancel()
        return None
    except Exception as e:
        logger.error(f"❌ Gemini text call failed: {type(e).__name__}: {e}")
        # Reset model on auth/model errors so it reinitialises
        if "API_KEY" in str(e) or "model" in str(e).lower() or "404" in str(e):
            logger.warning("Resetting Gemini model cache due to error.")
            _reset_model()
        return None


def call_gemini_json(
    prompt: str,
    expected_keys: list[str],
    timeout_seconds: float = 15.0,
) -> Optional[Dict[str, Any]]:
    """
    Call Gemini and expect a strict JSON response.

    Args:
        prompt: Full prompt text telling Gemini to return JSON only.
        expected_keys: Keys that MUST be present in the response.
        timeout_seconds: Max seconds to wait (REAL enforcement).

    Returns:
        Parsed dict if valid, None on any failure.
    """
    model = _get_model()
    if model is None:
        return None

    def _do_call():
        response = model.generate_content(
            prompt,
            generation_config={
                "temperature": 0.1,     # Low temp = deterministic JSON
                "max_output_tokens": 512,
            },
        )
        return response.text.strip()

    try:
        future = _executor.submit(_do_call)
        raw = future.result(timeout=timeout_seconds)
        return _parse_and_validate_json(raw, expected_keys)
    except concurrent.futures.TimeoutError:
        logger.warning(f"⏱️ Gemini JSON call timed out after {timeout_seconds}s")
        future.cancel()
        return None
    except Exception as e:
        logger.warning(f"❌ Gemini JSON call failed: {type(e).__name__}: {e}")
        if "API_KEY" in str(e) or "model" in str(e).lower() or "404" in str(e):
            _reset_model()
        return None


def call_gemini_json_with_retry(
    prompt: str,
    strict_prompt: str,
    expected_keys: list[str],
    timeout_seconds: float = 15.0,
) -> Optional[Dict[str, Any]]:
    """
    Try Gemini with prompt first, then retry with strict_prompt if parsing fails.
    Returns parsed dict if valid on either attempt, None if both fail.
    """
    result = call_gemini_json(prompt, expected_keys, timeout_seconds)
    if result is not None:
        return result

    logger.info("First Gemini attempt failed — retrying with strict prompt.")
    result = call_gemini_json(strict_prompt, expected_keys, timeout_seconds)
    return result


def _parse_and_validate_json(
    raw: str,
    required_keys: list[str],
) -> Optional[Dict[str, Any]]:
    """
    Extract and validate JSON from Gemini response.
    Handles markdown fences, leading text, etc.
    """
    # Strip markdown code fences
    if "```json" in raw:
        raw = raw.split("```json", 1)[1]
        raw = raw.split("```", 1)[0]
    elif "```" in raw:
        raw = raw.split("```", 1)[1]
        raw = raw.split("```", 1)[0]

    raw = raw.strip()

    # Find JSON object boundaries
    start = raw.find("{")
    end = raw.rfind("}") + 1
    if start == -1 or end == 0:
        logger.warning(f"No JSON object found in Gemini response: {raw[:200]}")
        return None

    json_str = raw[start:end]

    try:
        parsed = json.loads(json_str)
    except json.JSONDecodeError as e:
        logger.warning(f"JSON parse error: {e} | raw: {json_str[:200]}")
        return None

    # Validate required keys
    missing = [k for k in required_keys if k not in parsed]
    if missing:
        logger.warning(f"Gemini response missing keys {missing}: {parsed}")
        return None

    return parsed
